# ========================================================
# Equity-Copilot - Supabase Cloud Database Configuration
# Paste your Supabase credentials here to transition from 
# Local Sandbox Mode into production Cloud PostgreSQL Mode.
# ========================================================

# 1. Supabase Project REST API URL
# Locate this in Supabase Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project-id.supabase.co

# 2. Supabase Anon Public API Key
# Locate this in Supabase Project Settings -> API -> Project API Keys (anon / public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-api-key-string

# ========================================================
# Note: After pasting your keys, restart your Next.js server:
# 1. Stop terminal command (Ctrl + C)
# 2. Run 'npm run dev' to boot terminal with new environment variables
# ========================================================
